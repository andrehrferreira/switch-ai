{
  "name": "switch-ai",
  "version": "0.1.0",
  "description": "Intelligent model router that automatically selects the best AI model for your task, optimizing cost and performance",
  "bin": {
    "switch-ai": "dist/cli/index.cjs"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit && npx esbuild src/cli/index.ts --bundle --platform=node --target=node18 --format=cjs --external:better-sqlite3 --banner:js=\"#!/usr/bin/env node\" --outfile=dist/cli/index.cjs",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.cjs start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "llm",
    "model-routing",
    "cost-optimization",
    "claude",
    "anthropic",
    "openrouter",
    "litellm",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/switch-ai"
  },
  "bugs": {
    "url": "https://github.com/yourusername/switch-ai/issues"
  },
  "homepage": "https://github.com/yourusername/switch-ai#readme",
  "dependencies": {
    "axios": "^1.6.8",
    "better-sqlite3": "^12.6.0",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "fastify": "^5.7.4",
    "node-fetch": "^3.3.2",
    "openai": "^6.25.0",
    "ora": "^8.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}