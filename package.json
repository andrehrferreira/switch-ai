{
  "name": "switch-ai",
  "version": "0.3.0",
  "description": "Intelligent model router that automatically selects the best AI model for your task, optimizing cost and performance",
  "bin": {
    "switch-ai": "dist/cli/index.cjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && npx esbuild src/cli/index.ts --bundle --platform=node --target=node18 --format=cjs --external:sql.js --banner:js=\"#!/usr/bin/env node\" --outfile=dist/cli/index.cjs",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.cjs start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ai",
    "llm",
    "model-routing",
    "cost-optimization",
    "claude",
    "anthropic",
    "openrouter",
    "litellm",
    "proxy"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrehrferreira/switch-ai"
  },
  "bugs": {
    "url": "https://github.com/andrehrferreira/switch-ai/issues"
  },
  "homepage": "https://github.com/andrehrferreira/switch-ai#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.8.2",
    "node-fetch": "^3.3.2",
    "openai": "^6.27.0",
    "ora": "^8.0.1",
    "sql.js": "^1.14.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^8.57.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
