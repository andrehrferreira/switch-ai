# Switch AI Configuration
# Copy this file to .env and fill in your values

# ============================================================
# CORE SETTINGS
# ============================================================

# Port where Switch AI proxy server listens
SWITCH_AI_PORT=4000

# Logging level: debug, info, warn, error
SWITCH_AI_LOG_LEVEL=info

# Path to store local memory database
SWITCH_AI_MEMORY_PATH=~/.switch-ai

# Days to keep history in memory database
SWITCH_AI_MEMORY_RETENTION=90

# ============================================================
# API KEYS (Optional - auto-detected if available)
# ============================================================

# Anthropic API key for Claude models via OpenRouter
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter API key for accessing multiple models
OPENROUTER_API_KEY=sk-or-...

# Google Gemini API key for Gemini models
GEMINI_API_KEY=...

# OpenAI API key (if using OpenAI models)
OPENAI_API_KEY=sk-...

# ============================================================
# MODEL PREFERENCES
# ============================================================

# Prioritize local models (Ollama) over API calls
SWITCH_AI_PREFER_LOCAL_MODELS=false

# Strict mode: require exact model match (no fallback)
SWITCH_AI_STRICT_MODE=false

# Default complexity tier: free, cheap, balanced, premium
SWITCH_AI_DEFAULT_TIER=balanced

# Maximum cost per request (in USD, 0 = unlimited)
SWITCH_AI_MAX_COST_PER_REQUEST=0.10

# ============================================================
# VALIDATION & ESCALATION
# ============================================================

# Enable response quality validation
SWITCH_AI_VALIDATE_RESPONSES=true

# Number of escalation retries if validation fails
SWITCH_AI_ESCALATION_RETRIES=2

# ============================================================
# META-AI SELECTION (for decision making)
# ============================================================

# Which model to use as the meta-AI decision maker
# Options: haiku, deepseek, gemini-flash, claude-code
SWITCH_AI_META_AI_MODEL=haiku

# Use local meta-AI if available (for privacy)
SWITCH_AI_META_AI_LOCAL=false

# ============================================================
# LITELLM CONFIGURATION (if using LiteLLM backend)
# ============================================================

# LiteLLM API key
LITELLM_API_KEY=...

# LiteLLM master key
LITELLM_MASTER_KEY=...

# LiteLLM database URL (if using database routing)
LITELLM_DATABASE_URL=...

# ============================================================
# DEVELOPMENT & DEBUG
# ============================================================

# Enable debug logging and verbose output
SWITCH_AI_DEBUG=false

# Disable model routing (use default model)
SWITCH_AI_DISABLE_ROUTING=false

# Test mode: log decisions but don't actually call models
SWITCH_AI_TEST_MODE=false

# ============================================================
# FEATURE FLAGS
# ============================================================

# Enable learning and model performance tracking
SWITCH_AI_LEARNING_ENABLED=true

# Enable automatic model blacklisting on repeated failures
SWITCH_AI_AUTO_BLACKLIST=true

# Enable cost prediction
SWITCH_AI_COST_PREDICTION=true

# Enable usage analytics
SWITCH_AI_ANALYTICS=false
